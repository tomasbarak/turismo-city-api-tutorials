# Copy to .env (or export these) before running the examples.

# From your RapidAPI dashboard:
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=turismocity-api.p.rapidapi.com

# Optional: point examples at a direct deployment instead of the RapidAPI gateway.
# When set, RapidAPI headers are omitted (works if the API is in open mode).
# BASE_URL=https://your-app.up.railway.app
